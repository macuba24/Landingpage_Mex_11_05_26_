# LangSmith tracing (Control Agent / Master Console backend)
# Copy to .env and replace YOUR_LANGSMITH_API_KEY with your key from https://smith.langchain.com
LANGCHAIN_TRACING_V2=true
LANGCHAIN_ENDPOINT="https://api.smith.langchain.com"
LANGCHAIN_API_KEY="ls__YOUR_LANGSMITH_API_KEY"
LANGCHAIN_PROJECT="control-agent-automotive"
